# ─── Gotham Cricket Backend — environment variable template ──────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
#
# Usage (load before running the app):
#   source .env && ./mvnw spring-boot:run
#   export $(grep -v '^#' .env | xargs) && java -jar target/*.jar
#
# On EC2 / systemd: set these as EnvironmentFile= or Environment= in the
# service unit, or export them in the startup script before launching the jar.

# ─── Database ────────────────────────────────────────────────────────────────
# Local:   jdbc:mysql://localhost:3306/gotham_cricket_club?useSSL=false&serverTimezone=UTC
# EC2/RDS: jdbc:mysql://<rds-endpoint>:3306/gotham_cricket_club
DB_URL=jdbc:mysql://localhost:3306/gotham_cricket_club?useSSL=false&serverTimezone=UTC
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_with_a_long_random_base64_string
JWT_EXPIRATION=1296000000

# ─── Email (Gmail App Password) ──────────────────────────────────────────────
# Enable 2FA on Gmail, then create an App Password at myaccount.google.com/apppasswords
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── WebSocket ───────────────────────────────────────────────────────────────
# React Native has no browser origin, so * is required here
WEBSOCKET_ALLOWED_ORIGIN_PATTERNS=*

# ─── CORS ────────────────────────────────────────────────────────────────────
# Development: http://localhost:8081
# Production:  https://your-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:8081

# ─── HTTPS ───────────────────────────────────────────────────────────────────
HTTPS_ENABLED=false
